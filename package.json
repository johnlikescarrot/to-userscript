{
  "name": "to-userscript",
  "version": "1.0.0",
  "description": "The ultimate browser extension to userscript converter, release-ready and strictly typed.",
  "type": "module",
  "main": "./dist/index.js",
  "bin": {
    "to-userscript": "./dist/cli/index.js"
  },
  "exports": {
    ".": "./dist/index.js"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "dev": "tsup src/cli/index.ts --watch --onSuccess 'node dist/cli/index.js'",
    "build": "tsup src/index.ts src/cli/index.ts --format esm --dts --clean",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "lint": "tsc --noEmit",
    "start": "node dist/cli/index.js"
  },
  "dependencies": {
    "chalk": "^5.3.0",
    "cli-progress": "^3.12.0",
    "debug": "^4.4.0",
    "fs-extra": "^11.2.0",
    "node-fetch": "^3.3.2",
    "ora": "^8.0.1",
    "prettier": "^3.5.3",
    "terser": "^5.37.0",
    "tmp": "^0.2.3",
    "yargs": "^17.7.2",
    "yauzl": "^3.0.0",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@types/cli-progress": "^3.11.5",
    "@types/debug": "^4.1.12",
    "@types/fs-extra": "^11.0.4",
    "@types/node": "^20.11.0",
    "@types/tmp": "^0.2.6",
    "@types/yargs": "^17.0.32",
    "@types/yauzl": "^2.10.3",
    "@vitest/coverage-v8": "^3.0.5",
    "tsup": "^8.4.0",
    "typescript": "^5.7.3",
    "vitest": "^3.0.5"
  }
}
